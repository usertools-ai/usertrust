{
	"formatter": {
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": { "recommended": true }
	},
	"files": {
		"ignore": [
			"**/dist/**",
			"**/coverage/**",
			"**/.usertrust/**",
			"**/.usertrust-gate1/**",
			"**/.source/**",
			"**/.next/**"
		]
	},
	"overrides": [
		{
			"include": ["scripts/**"],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		},
		{
			"include": ["site/app/components/typewriter-code.tsx"],
			"linter": {
				"rules": {
					"suspicious": {
						"noArrayIndexKey": "off"
					}
				}
			}
		}
	]
}
