{
	"name": "usertrust",
	"version": "1.0.0",
	"description": "Financial governance for AI agents. Every LLM call becomes an immutable, auditable transaction.",
	"license": "Apache-2.0",
	"author": "Usertools, Inc. <hello@usertools.ai> (https://usertrust.ai)",
	"homepage": "https://usertrust.ai",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/usertools-ai/usertrust.git",
		"directory": "packages/core"
	},
	"bugs": "https://github.com/usertools-ai/usertrust/issues",
	"keywords": [
		"ai",
		"governance",
		"llm",
		"audit",
		"financial",
		"agent",
		"budget",
		"token",
		"anthropic",
		"openai",
		"tigerbeetle",
		"ledger"
	],
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"bin": {
		"usertrust": "./dist/cli/main.js"
	},
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./headless": {
			"import": "./dist/headless.js",
			"types": "./dist/headless.d.ts"
		},
		"./pricing": {
			"import": "./dist/ledger/pricing.js",
			"types": "./dist/ledger/pricing.d.ts"
		}
	},
	"dependencies": {
		"@clack/prompts": "^1.1.0",
		"minimatch": "^10.2.4",
		"picocolors": "^1.1.1",
		"tigerbeetle-node": "^0.16.0",
		"yaml": "^2.8.3",
		"zod": "^3.23.0"
	},
	"scripts": {
		"build": "tsc",
		"prepublishOnly": "tsc"
	},
	"files": ["dist"],
	"peerDependencies": {
		"@anthropic-ai/sdk": ">=0.30.0",
		"openai": ">=4.70.0"
	},
	"peerDependenciesMeta": {
		"@anthropic-ai/sdk": {
			"optional": true
		},
		"openai": {
			"optional": true
		}
	}
}
